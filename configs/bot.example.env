# Example Bot Configuration
# Copy to bot.env and customize

# API Configuration
PUMPAPI_API_KEY=your_api_key_here
PUMPAPI_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
PUMPAPI_WSS_URL=wss://pumpportal.fun/api/data

# Wallet Configuration
PUMPAPI_WALLET_PRIVATE_KEY=your_base58_private_key
TRADER_WALLET_ADDRESS=your_wallet_address

# Trading Parameters
DEFAULT_SLIPPAGE_BPS=100
DEFAULT_PRIORITY_FEE=5000
MAX_POSITION_SOL=1.0
MAX_DAILY_LOSS_SOL=5.0

# Strategy Configuration
STRATEGY_ENABLED=true
STRATEGY_MIN_MARKET_CAP=500
STRATEGY_MAX_MARKET_CAP=10000
STRATEGY_MIN_LIQUIDITY=50

# Monitoring
ENABLE_LOGGING=true
LOG_LEVEL=INFO
METRICS_ENABLED=true
