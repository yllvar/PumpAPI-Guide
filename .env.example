# pumpAPI Configuration
# Copy this file to .env and fill in your values

# API Authentication (choose one method)
PUMPAPI_API_KEY=your_api_key_here

# OR Wallet-based authentication
PUMPAPI_WALLET_PRIVATE_KEY=your_base58_private_key

# RPC Configuration
PUMPAPI_RPC_URL=https://api.mainnet-beta.solana.com
PUMPAPI_RPC_URL_BACKUP=https://api.mainnet-beta.solana.com

# WebSocket Configuration
PUMPAPI_WSS_URL=wss://pumpportal.fun/api/data

# Trading Configuration
PUMPAPI_SLIPPAGE_BPS=100
PUMPAPI_PRIORITY_FEE_MICRO_LAMPORTS=1000

# Trading Wallet (for wallet-based auth)
TRADER_WALLET_ADDRESS=your_wallet_address

# Optional: Debug mode
PUMPAPI_DEBUG=false
